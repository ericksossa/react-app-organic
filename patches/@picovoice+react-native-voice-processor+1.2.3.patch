+    @objc private func handleInterruption(_ notification: Notification) {
+        guard let info = notification.userInfo,
+              let typeInt = info[AVAudioSessionInterruptionTypeKey] as? UInt,
+              let type = AVAudioSession.InterruptionType(rawValue: typeInt) else {
+            return
+        }
+
+        switch type {
+        case .began:
+            shouldResumeAfterInterruption = voiceProcessor.isRecording
+            emitDiagnostic("audio_interruption_began", extra: ["wasRecording": shouldResumeAfterInterruption])
+        case .ended:
+            let optionsRaw = info[AVAudioSessionInterruptionOptionKey] as? UInt ?? 0
+            let shouldResume = AVAudioSession.InterruptionOptions(rawValue: optionsRaw).contains(.shouldResume)
+            emitDiagnostic("audio_interruption_ended", extra: ["shouldResume": shouldResume])
+            if shouldResumeAfterInterruption && shouldResume {
+                do {
+                    try restartVoiceProcessor(reason: "interruption_ended")
+                } catch {
+                    DispatchQueue.main.async {
+                        self.sendEvent(withName: self.errorEmitterKey, body: "interruption_restart_failed: \(error.localizedDescription)")
+                    }
+                }
+            }
+            shouldResumeAfterInterruption = false
+        @unknown default:
+            break
+        }
+    }
+
+    private func handleFrame(_ frame: [Int16]) {
+        nativeFrameCount += 1
+
+        guard nativeCheetahEnabled, let cheetah = nativeCheetah else {
+            let normalizedFrame: [Double] = frame.map { Double(Int($0)) }
+            DispatchQueue.main.async {
+                self.sendEvent(withName: self.frameEmitterKey, body: normalizedFrame)
+            }
+            return
+        }
+
+        do {
+            let (chunkText, _) = try cheetah.process(frame)
+            let trimmed = chunkText.trimmingCharacters(in: .whitespacesAndNewlines)
+            if trimmed.isEmpty { return }
+
+            partialTranscript = [partialTranscript, trimmed]
+                .filter { !$0.isEmpty }
+                .joined(separator: " ")
+
+            let now = nowMs()
+            if firstPartialAtMs == 0 { firstPartialAtMs = now }
+            if now - lastPartialEmitAtMs < 100 { return }
+            lastPartialEmitAtMs = now
+            partialEventCount += 1
+
+            let durationMs = max(1, now - sessionStartedAtMs)
+            let rate = Double(partialEventCount) / max(1.0, Double(durationMs) / 1000.0)
+
+            let payload: [String: Any] = [
+                "text": partialTranscript,
+                "time_to_first_partial_ms": max(0, firstPartialAtMs - sessionStartedAtMs),
+                "partial_event_rate": rate,
+                "frames_emitted_native": nativeFrameCount
+            ]
+            DispatchQueue.main.async {
+                self.sendEvent(withName: self.partialTextEmitterKey, body: payload)
+            }
+        } catch {
+            DispatchQueue.main.async {
+                self.sendEvent(withName: self.errorEmitterKey, body: "native_process_failed: \(error.localizedDescription)")
+            }
+        }
+    }
+
+    private func registerAudioNotifications() {
+        let center = NotificationCenter.default
+        center.removeObserver(self, name: AVAudioSession.routeChangeNotification, object: nil)
+        center.removeObserver(self, name: AVAudioSession.interruptionNotification, object: nil)
+        center.addObserver(self, selector: #selector(handleRouteChange(_:)), name: AVAudioSession.routeChangeNotification, object: nil)
+        center.addObserver(self, selector: #selector(handleInterruption(_:)), name: AVAudioSession.interruptionNotification, object: nil)
+    }
+
+    private func unregisterAudioNotifications() {
+        let center = NotificationCenter.default
+        center.removeObserver(self, name: AVAudioSession.routeChangeNotification, object: nil)
+        center.removeObserver(self, name: AVAudioSession.interruptionNotification, object: nil)
+    }
+
+    private func configureAudioSession() throws {
+        let audioSession = AVAudioSession.sharedInstance()
+        try? audioSession.setActive(false, options: .notifyOthersOnDeactivation)
+        try audioSession.setCategory(.playAndRecord, mode: .measurement, options: [.defaultToSpeaker, .allowBluetooth])
+        try audioSession.setPreferredSampleRate(16000)
+        try audioSession.setPreferredIOBufferDuration(0.02)
+        try audioSession.setActive(true, options: .notifyOthersOnDeactivation)
+    }
+
+    private func restartVoiceProcessor(reason: String) throws {
+        if isRestartingAudio { return }
+        isRestartingAudio = true
+        defer { isRestartingAudio = false }
+
+        let wasRecording = voiceProcessor.isRecording
+        if wasRecording {
+            try? voiceProcessor.stop()
+        }
+
+        try configureAudioSession()
+
+        if wasRecording {
+            try voiceProcessor.start(frameLength: UInt32(desiredFrameLength), sampleRate: UInt32(desiredSampleRate))
+        }
+
+        emitDiagnostic("audio_restarted", extra: [
+            "reason": reason,
+            "frameLength": desiredFrameLength,
+            "sampleRate": desiredSampleRate
+        ])
+    }
+
+    private func emitDiagnostic(_ event: String, extra: [String: Any]) {
+        var payload = audioDiagnostics()
+        payload["event"] = event
+        for (key, value) in extra {
+            payload[key] = value
+        }
+        DispatchQueue.main.async {
+            self.sendEvent(withName: self.diagnosticEmitterKey, body: payload)
+        }
+    }
+
+    private func audioDiagnostics() -> [String: Any] {
+        let session = AVAudioSession.sharedInstance()
+        let route = session.currentRoute
+        let inputs = route.inputs.map { "\($0.portName)(\($0.portType.rawValue))" }
+        let outputs = route.outputs.map { "\($0.portName)(\($0.portType.rawValue))" }
+
+        return [
+            "recordPermission": permissionLabel(session.recordPermission),
+            "category": session.category.rawValue,
+            "mode": session.mode.rawValue,
+            "sampleRate": session.sampleRate,
+            "preferredSampleRate": session.preferredSampleRate,
+            "ioBufferDuration": session.ioBufferDuration,
+            "preferredIoBufferDuration": session.preferredIOBufferDuration,
+            "currentRouteInputs": inputs,
+            "currentRouteOutputs": outputs,
+            "isInputAvailable": session.isInputAvailable,
+            "engineRunning": voiceProcessor.isRecording,
+            "frames_emitted_native": nativeFrameCount,
+            "time_to_first_partial_ms": firstPartialAtMs > 0 ? max(0, firstPartialAtMs - sessionStartedAtMs) : -1,
+            "partial_event_rate": partialEventRate()
+        ]
+    }
+
+    private func partialEventRate() -> Double {
+        let durationMs = nowMs() - sessionStartedAtMs
+        if durationMs <= 0 { return 0 }
+        return Double(partialEventCount) / (Double(durationMs) / 1000.0)
+    }
+
+    private func permissionLabel(_ permission: AVAudioSession.RecordPermission) -> String {
+        switch permission {
+        case .granted: return "granted"
+        case .denied: return "denied"
+        case .undetermined: return "undetermined"
+        @unknown default: return "unknown"
+        }
+    }
+
+    private func routeChangeReason(_ notification: Notification) -> String {
+        guard let info = notification.userInfo,
+              let raw = info[AVAudioSessionRouteChangeReasonKey] as? UInt,
+              let reason = AVAudioSession.RouteChangeReason(rawValue: raw) else {
+            return "unknown"
+        }
+
+        switch reason {
+        case .newDeviceAvailable: return "newDeviceAvailable"
+        case .oldDeviceUnavailable: return "oldDeviceUnavailable"
+        case .categoryChange: return "categoryChange"
+        case .override: return "override"
+        case .wakeFromSleep: return "wakeFromSleep"
+        case .noSuitableRouteForCategory: return "noSuitableRouteForCategory"
+        case .routeConfigurationChange: return "routeConfigurationChange"
+        case .unknown: return "unknown"
+        @unknown default: return "unknownDefault"
+        }
+    }
+
+    private func nowMs() -> Int {
+        Int(Date().timeIntervalSince1970 * 1000)
+    }
+
+    private func voiceLog(_ message: String, payload: [String: Any] = [:]) {
+        if payload.isEmpty {
+            NSLog("[voice-debug][ios] \(message)")
+            return
+        }
+        NSLog("[voice-debug][ios] \(message) \(payload)")
+    }
+
+    deinit {
+        settingsTimer?.invalidate()
+        unregisterAudioNotifications()
+        nativeCheetah?.delete()
+    }
 }
