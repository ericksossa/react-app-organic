+    @objc private func handleRouteChange(_ notification: Notification) {
+        let reason = routeChangeReason(notification)
+        voiceLog("route_change", payload: ["reason": reason].merging(audioDiagnostics()) { _, new in new })
+        emitDiagnostic("route_change", extra: ["reason": reason])
+
+        guard voiceProcessor.isRecording else { return }
+        if reason != "newDeviceAvailable" && reason != "oldDeviceUnavailable" && reason != "routeConfigurationChange" {
+            return
+        }
+
+        let now = nowMs()
+        if now - lastRestartTsMs < 1200 { return }
+        lastRestartTsMs = now
+
+        do {
+            try restartVoiceProcessor(reason: "route_change_\(reason)")
+        } catch {
+            DispatchQueue.main.async {
+                self.sendEvent(withName: self.errorEmitterKey, body: "route_change_restart_failed: \(error.localizedDescription)")
+            }
+        }
     }
